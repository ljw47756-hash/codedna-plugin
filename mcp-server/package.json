{
  "name": "@codedna/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for the CodeDNA Codex plugin.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run build",
    "presmoke": "npm run build",
    "smoke": "tsx scripts/e2e.ts",
    "smoke:tools": "tsx test/manualSmoke.ts",
    "validate:real-project": "tsx scripts/realProjectWorkflow.ts",
    "release:check": "tsx scripts/releaseCheck.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
